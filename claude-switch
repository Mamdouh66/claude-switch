#!/bin/bash
# claude-switch вЂ” fast profile switcher for Claude Code on macOS
# Swaps OAuth credentials in the macOS Keychain between named profiles.

set -e

VERSION="0.3.0"
KEYCHAIN_SERVICE="Claude Code-credentials"
KEYCHAIN_ACCOUNT="$(whoami)"
ACTIVE_FILE="$HOME/.claude/.active-profile"
PROFILE_PREFIX="Claude Code-credentials-"
CONFIG_DIR="$HOME/.config/claude-switch"
CONFIG_FILE="$CONFIG_DIR/config"
# Isolated mode: each profile is its own CLAUDE_CONFIG_DIR (separate login,
# own refresh token, can run concurrently). See `claude-switch mode`.
ISOLATED_DIR="$CONFIG_DIR/profiles"

# в”Ђв”Ђ Colors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
DIM='\033[2m'
BOLD='\033[1m'
UNDERLINE='\033[4m'
NC='\033[0m'

# в”Ђв”Ђ Config в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

get_config() {
    local key="$1"
    local default="$2"
    if [ -f "$CONFIG_FILE" ]; then
        local val
        val=$(grep "^${key}=" "$CONFIG_FILE" 2>/dev/null | head -1 | cut -d'=' -f2-)
        [ -n "$val" ] && echo "$val" || echo "$default"
    else
        echo "$default"
    fi
}

set_config() {
    local key="$1"
    local value="$2"
    mkdir -p "$CONFIG_DIR"
    if [ -f "$CONFIG_FILE" ] && grep -q "^${key}=" "$CONFIG_FILE" 2>/dev/null; then
        sed -i '' "s|^${key}=.*|${key}=${value}|" "$CONFIG_FILE"
    else
        echo "${key}=${value}" >> "$CONFIG_FILE"
    fi
}

# в”Ђв”Ђ Helpers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

get_active_profile() {
    cat "$ACTIVE_FILE" 2>/dev/null || echo ""
}

set_active_profile() {
    mkdir -p "$(dirname "$ACTIVE_FILE")"
    echo "$1" > "$ACTIVE_FILE"
}

# keychain (default) | isolated
get_mode() {
    get_config "mode" "keychain"
}

profile_dir() {
    echo "${ISOLATED_DIR}/$1"
}

isolated_profiles() {
    [ -d "$ISOLATED_DIR" ] || return 0
    find "$ISOLATED_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null \
        | sed 's#.*/##' | sort -u
}

# status|sub|email for an isolated profile by running auth status in its dir
isolated_info() {
    local dir="$1"
    CLAUDE_CONFIG_DIR="$dir" claude auth status 2>/dev/null | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
except Exception:
    print('error||'); sys.exit(0)
if d.get('loggedIn'):
    print(f\"ready|{d.get('subscriptionType','?')}|{d.get('email','')}\")
else:
    print('logged-out||')
" 2>/dev/null || echo "error||"
}

get_token_info() {
    local service="$1"
    local creds
    creds=$(security find-generic-password -s "$service" -w 2>/dev/null) || return 1
    echo "$creds" | python3 -c "
import sys, json, time
d = json.load(sys.stdin)
oauth = d.get('claudeAiOauth', {})
exp = oauth.get('expiresAt', 0)
sub = oauth.get('subscriptionType', '?')
email = oauth.get('email', '')
has_refresh = bool(oauth.get('refreshToken'))
now = time.time() * 1000
remaining = (exp - now) / 1000 / 60
if remaining > 0:
    # Access token still fresh.
    if remaining > 60:
        time_str = f'{remaining/60:.1f}h left'
    else:
        time_str = f'{remaining:.0f}m left'
    status = 'valid'
elif has_refresh:
    # Access token lapsed, but the long-lived refresh token will mint a
    # new one on next use. The account is healthy, not expired.
    status = 'ready'
    time_str = 'auto-refresh'
else:
    # No refresh token: this profile is genuinely dead and needs re-auth.
    status = 'expired'
    time_str = 'expired'
print(f'{status}|{sub}|{time_str}|{email}')
" 2>/dev/null
}

get_account_email() {
    local creds
    creds=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null) || return 1
    claude auth status 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(d.get('email', 'unknown'))
" 2>/dev/null
}

list_profiles() {
    if [ "$(get_mode)" = "isolated" ]; then
        isolated_profiles
        return
    fi
    security dump-keychain 2>/dev/null | grep '"svce"' | grep "Claude Code-credentials-" | \
        sed 's/.*"Claude Code-credentials-//' | sed 's/".*//' | sort -u
}

do_refresh() {
    local profile="$1"
    claude auth status >/dev/null 2>&1 || true
    local creds
    creds=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null) || return 1
    security add-generic-password -U -s "${PROFILE_PREFIX}${profile}" -a "$KEYCHAIN_ACCOUNT" -w "$creds" 2>/dev/null
}

# в”Ђв”Ђ Commands в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

show_status() {
    local active
    active=$(get_active_profile)

    local profiles
    profiles=$(list_profiles)
    if [ -z "$profiles" ]; then
        echo ""
        if [ "$(get_mode)" = "isolated" ]; then
            echo -e "  ${DIM}No profiles yet. Create one:${NC} ${BOLD}claude-switch <name>${NC}"
            echo -e "  ${DIM}then launch it with your shortcut to log in.${NC}"
        else
            echo -e "  ${DIM}No profiles yet. Run:${NC} ${BOLD}claude-switch setup${NC}"
        fi
        echo ""
        return
    fi

    local alias_name mode
    alias_name=$(get_config "alias" "c")
    mode=$(get_mode)

    echo ""
    if [ "$mode" = "isolated" ]; then
        echo -e "  ${DIM}Profiles${NC} ${DIM}(isolated)${NC}"
    else
        echo -e "  ${DIM}Profiles${NC}"
    fi
    echo -e "  ${DIM}в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ${NC}"

    while IFS= read -r profile; do
        [[ -z "$profile" ]] && continue
        local info marker color sub_color status sub time_str email
        if [ "$mode" = "isolated" ]; then
            info=$(isolated_info "$(profile_dir "$profile")") || info="error||"
            IFS='|' read -r status sub email <<< "$info"
            time_str="$status"
        else
            info=$(get_token_info "${PROFILE_PREFIX}${profile}" 2>/dev/null) || info="error|?|?|"
            IFS='|' read -r status sub time_str email <<< "$info"
        fi

        if [ "$profile" = "$active" ]; then
            marker="${GREEN}в—Џ${NC}"
        else
            marker="${DIM}в—‹${NC}"
        fi

        case "$status" in
            valid)   color="${GREEN}" ;;
            ready)   color="${CYAN}" ;;
            expired) color="${YELLOW}" ;;
            *)       color="${RED}" ;;
        esac

        case "$sub" in
            max)  sub_color="${MAGENTA}" ;;
            team) sub_color="${BLUE}" ;;
            pro)  sub_color="${CYAN}" ;;
            *)    sub_color="${DIM}" ;;
        esac

        printf "  %b  ${BOLD}%-12s${NC}  %b%-4s${NC}  %b%-10s${NC}" \
            "$marker" "$profile" "$sub_color" "$sub" "$color" "$time_str"
        if [ -n "$email" ]; then
            printf "  ${DIM}%s${NC}" "$email"
        fi
        printf "\n"
    done <<< "$profiles"

    # Warn if an env var overrides the swapped profile. Claude Code's auth
    # precedence puts these ahead of the subscription OAuth we swap in, so a
    # set key means the active profile above is NOT what Claude actually uses.
    local override=""
    if [ -n "$ANTHROPIC_API_KEY" ]; then
        override="ANTHROPIC_API_KEY"
    elif [ -n "$ANTHROPIC_AUTH_TOKEN" ]; then
        override="ANTHROPIC_AUTH_TOKEN"
    elif [ -n "$CLAUDE_CODE_OAUTH_TOKEN" ]; then
        override="CLAUDE_CODE_OAUTH_TOKEN"
    fi
    if [ -n "$override" ]; then
        echo ""
        echo -e "  ${YELLOW}!${NC} ${BOLD}${override}${NC} is set вЂ” it overrides the active profile."
        echo -e "    ${DIM}Claude Code will use that, not the swapped credentials. unset it to switch.${NC}"
    fi

    echo ""
    echo -e "  ${DIM}Switch: ${NC}${BOLD}${alias_name} <profile>${NC}${DIM}  |  Status: ${NC}${BOLD}${alias_name} status${NC}"
    echo ""
}

do_setup() {
    local alias_name
    local -a pending_names=()
    local -a pending_creds=()

    if [ "$(get_mode)" = "isolated" ]; then
        echo ""
        echo -e "  ${BOLD}claude-switch${NC} ${DIM}setup (isolated mode)${NC}"
        echo -e "  ${DIM}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
        echo ""
        echo -e "  In isolated mode each profile is its own config dir, so there's"
        echo -e "  nothing to capture up front. To add an account:"
        echo ""
        echo -e "    ${BOLD}claude-switch <name>${NC}   ${DIM}create the profile${NC}"
        echo -e "    ${BOLD}$(get_config alias c) <name>${NC}              ${DIM}launch it вЂ” Claude prompts you to log in${NC}"
        echo ""
        echo -e "  ${DIM}Repeat for each account. Switch back to keychain mode with:${NC}"
        echo -e "  ${BOLD}claude-switch mode keychain${NC}"
        echo ""
        return 0
    fi

    trap 'printf "${NC}\n\n  ${DIM}Setup cancelled. Nothing was saved.${NC}\n\n"; return 1' INT

    echo ""
    echo -e "  ${BOLD}claude-switch${NC} ${DIM}setup${NC}"
    echo -e "  ${DIM}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
    echo ""

    # в”Ђв”Ђ Step 1: Choose alias в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    local current_alias
    current_alias=$(get_config "alias" "")

    echo -e "  ${CYAN}1${NC}  ${BOLD}Choose your shortcut${NC}"
    echo ""
    echo -e "     This is the command you'll type to launch Claude."
    echo -e "     ${DIM}Examples: c, cc, code, claude${NC}"
    echo ""
    if [ -n "$current_alias" ]; then
        printf "     Shortcut [${BOLD}%s${NC}]: " "$current_alias"
    else
        printf "     Shortcut [${BOLD}c${NC}]: "
    fi

    read -r alias_input
    alias_name="${alias_input:-${current_alias:-c}}"

    echo ""
    echo -e "     ${GREEN}вњ“${NC} ${BOLD}${alias_name}${NC}"
    echo ""

    # в”Ђв”Ђ Step 2: Add accounts в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "  ${CYAN}2${NC}  ${BOLD}Add your accounts${NC}"
    echo ""

    local auth_status
    auth_status=$(claude auth status 2>/dev/null) || auth_status=""

    if ! echo "$auth_status" | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if d.get('loggedIn') else 1)" 2>/dev/null; then
        echo -e "     ${YELLOW}!${NC} Not logged into Claude Code."
        echo -e "     Run ${BOLD}claude auth login${NC} first, then ${BOLD}claude-switch setup${NC} again."
        echo ""
        return 1
    fi

    local current_email current_sub creds

    # First account (already logged in)
    current_email=$(echo "$auth_status" | python3 -c "import sys,json; print(json.load(sys.stdin).get('email','?'))" 2>/dev/null)
    current_sub=$(echo "$auth_status" | python3 -c "import sys,json; print(json.load(sys.stdin).get('subscriptionType','?'))" 2>/dev/null)

    echo -e "     You're logged in as ${BOLD}${current_email}${NC} ${DIM}(${current_sub})${NC}"
    echo ""
    printf "     Name for this account: ${BOLD}"
    read -r profile_name
    printf "${NC}"

    if [ -z "$profile_name" ]; then
        echo -e "     ${DIM}Skipped.${NC}"
        echo ""
    else
        creds=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null) || {
            echo -e "     ${RED}вњ—${NC} Could not read credentials from Keychain"
            echo ""
            return 1
        }
        pending_names+=("$profile_name")
        pending_creds+=("$creds")
        echo -e "     ${GREEN}вњ“${NC} ${BOLD}${profile_name}${NC} ${DIM}(${current_email})${NC}"
        echo ""

        # Loop for more accounts
        while true; do
            printf "     Add another account? ${DIM}(y/n)${NC} "
            read -r add_more
            echo ""
            case "$add_more" in
                y|Y|yes)
                    echo -e "     ${DIM}Log into your other account:${NC}"
                    echo -e "     ${BOLD}claude auth logout && claude auth login${NC}"
                    echo ""
                    printf "     Press ${BOLD}enter${NC} when you're logged in..."
                    read -r
                    echo ""

                    auth_status=$(claude auth status 2>/dev/null) || auth_status=""
                    if echo "$auth_status" | python3 -c "import sys,json; d=json.load(sys.stdin); exit(0 if d.get('loggedIn') else 1)" 2>/dev/null; then
                        current_email=$(echo "$auth_status" | python3 -c "import sys,json; print(json.load(sys.stdin).get('email','?'))" 2>/dev/null)
                        current_sub=$(echo "$auth_status" | python3 -c "import sys,json; print(json.load(sys.stdin).get('subscriptionType','?'))" 2>/dev/null)

                        echo -e "     Logged in as ${BOLD}${current_email}${NC} ${DIM}(${current_sub})${NC}"
                        printf "     Name for this account: ${BOLD}"
                        read -r next_name
                        printf "${NC}"

                        if [ -n "$next_name" ]; then
                            creds=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null) || {
                                echo -e "     ${RED}вњ—${NC} Could not read credentials"
                                echo ""
                                continue
                            }
                            pending_names+=("$next_name")
                            pending_creds+=("$creds")
                            echo -e "     ${GREEN}вњ“${NC} ${BOLD}${next_name}${NC} ${DIM}(${current_email})${NC}"
                            echo ""
                        fi
                    else
                        echo -e "     ${YELLOW}!${NC} Not logged in вЂ” skipping. You can add it later with:"
                        echo -e "       ${BOLD}claude-switch save <name>${NC}"
                        echo ""
                    fi
                    ;;
                *)
                    break
                    ;;
            esac
        done
    fi

    # в”Ђв”Ђ Step 3: Apply everything в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "  ${CYAN}3${NC}  ${BOLD}Saving...${NC}"
    echo ""

    # Write config
    set_config "alias" "$alias_name"

    # Write all profiles to keychain
    local last_name=""
    for i in "${!pending_names[@]}"; do
        local name="${pending_names[$i]}"
        local cred="${pending_creds[$i]}"
        security add-generic-password -U -s "${PROFILE_PREFIX}${name}" -a "$KEYCHAIN_ACCOUNT" -w "$cred" 2>/dev/null || \
        security add-generic-password    -s "${PROFILE_PREFIX}${name}" -a "$KEYCHAIN_ACCOUNT" -w "$cred"
        last_name="$name"
        echo -e "     ${GREEN}вњ“${NC} Saved ${BOLD}${name}${NC} to Keychain"
    done

    # Set the last added profile as active
    if [ -n "$last_name" ]; then
        set_active_profile "$last_name"
    fi

    echo -e "     ${GREEN}вњ“${NC} Shortcut set to ${BOLD}${alias_name}${NC}"
    echo ""

    # в”Ђв”Ђ Summary в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    echo -e "  ${DIM}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
    echo ""

    local profiles
    profiles=$(list_profiles)
    if [ -n "$profiles" ]; then
        echo -e "  ${GREEN}Done!${NC} Your commands:"
        echo ""
        while IFS= read -r p; do
            [[ -z "$p" ]] && continue
            echo -e "    ${BOLD}${alias_name} ${p}${NC}${DIM}       switch + launch${NC}"
        done <<< "$profiles"
        echo -e "    ${BOLD}${alias_name} status${NC}${DIM}     show all profiles${NC}"
        echo -e "    ${BOLD}${alias_name}${NC}${DIM}            launch with current profile${NC}"
    fi

    echo ""
    echo -e "  Restart your shell or run: ${BOLD}source ~/.zshrc${NC}"
    echo ""

    trap - INT
}

usage() {
    echo ""
    echo -e "  ${BOLD}claude-switch${NC} ${DIM}v${VERSION}${NC}"
    echo ""
    echo -e "  ${BOLD}Usage:${NC} claude-switch ${CYAN}<command>${NC} ${DIM}[args]${NC}"
    echo ""
    echo -e "  ${CYAN}setup${NC}              Guided setup wizard"
    echo -e "  ${CYAN}<profile>${NC}          Switch to a profile"
    echo -e "  ${CYAN}status${NC}             Show all profiles and token health"
    echo -e "  ${CYAN}save${NC} ${DIM}<name>${NC}        Save current credentials as a profile"
    echo -e "  ${CYAN}list${NC}               List profile names"
    echo -e "  ${CYAN}remove${NC} ${DIM}<name>${NC}      Remove a saved profile"
    echo -e "  ${CYAN}refresh${NC}            Refresh the active profile's token"
    echo -e "  ${CYAN}alias${NC} ${DIM}[name]${NC}       Show or change the shell shortcut"
    echo -e "  ${CYAN}mode${NC} ${DIM}[name]${NC}        Show or set storage mode ${DIM}(keychain|isolated)${NC}"
    echo ""
    exit 0
}

# в”Ђв”Ђ Main в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

CMD="${1:-}"

case "$CMD" in
    setup)
        do_setup
        ;;

    status)
        show_status
        ;;

    "")
        show_status
        ;;

    save)
        SAVE_AS="${2:-}"
        if [ -z "$SAVE_AS" ]; then
            echo -e "${RED}вњ—${NC} Usage: claude-switch save ${DIM}<profile-name>${NC}"
            exit 1
        fi

        CREDS=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null) || {
            echo -e "${RED}вњ—${NC} No active Claude Code credentials. Log in first."
            exit 1
        }

        security add-generic-password -U -s "${PROFILE_PREFIX}${SAVE_AS}" -a "$KEYCHAIN_ACCOUNT" -w "$CREDS" 2>/dev/null || \
        security add-generic-password    -s "${PROFILE_PREFIX}${SAVE_AS}" -a "$KEYCHAIN_ACCOUNT" -w "$CREDS"
        set_active_profile "$SAVE_AS"
        echo -e "${GREEN}вњ“${NC} Saved current credentials as ${BOLD}${SAVE_AS}${NC}"
        ;;

    list)
        list_profiles
        ;;

    remove)
        PROFILE="${2:-}"
        if [ -z "$PROFILE" ]; then
            echo -e "${RED}вњ—${NC} Usage: claude-switch remove ${DIM}<profile-name>${NC}"
            exit 1
        fi
        if [ "$(get_mode)" = "isolated" ]; then
            DIR="$(profile_dir "$PROFILE")"
            if [ -d "$DIR" ]; then
                rm -rf "$DIR"
                echo -e "${GREEN}вњ“${NC} Removed profile ${BOLD}${PROFILE}${NC}"
            else
                echo -e "${RED}вњ—${NC} Profile '${PROFILE}' not found."
            fi
        else
            security delete-generic-password -s "${PROFILE_PREFIX}${PROFILE}" -a "$KEYCHAIN_ACCOUNT" 2>/dev/null && \
                echo -e "${GREEN}вњ“${NC} Removed profile ${BOLD}${PROFILE}${NC}" || \
                echo -e "${RED}вњ—${NC} Profile '${PROFILE}' not found."
        fi
        ;;

    refresh)
        ACTIVE=$(get_active_profile)
        if [ -z "$ACTIVE" ]; then
            echo -e "${RED}вњ—${NC} No active profile."
            exit 1
        fi
        if [ "$(get_mode)" = "isolated" ]; then
            # Isolated profiles keep their own refresh token and renew in place
            # on next use вЂ” there's nothing to copy. Nudge a renewal instead.
            CLAUDE_CONFIG_DIR="$(profile_dir "$ACTIVE")" claude auth status >/dev/null 2>&1 || true
            echo -e "${GREEN}вњ“${NC} ${BOLD}${ACTIVE}${NC} renews automatically on use."
            show_status
            exit 0
        fi
        echo -e "${DIM}Refreshing ${ACTIVE}...${NC}"
        do_refresh "$ACTIVE"
        echo -e "${GREEN}вњ“${NC} Token refreshed for ${BOLD}${ACTIVE}${NC}"
        show_status
        ;;

    mode)
        NEW_MODE="${2:-}"
        if [ -z "$NEW_MODE" ]; then
            echo -e "Current mode: ${BOLD}$(get_mode)${NC}"
            echo ""
            echo -e "  ${BOLD}keychain${NC}  ${DIM}swap one shared login in the macOS Keychain (default)${NC}"
            echo -e "  ${BOLD}isolated${NC}  ${DIM}each profile is its own CLAUDE_CONFIG_DIR вЂ” separate${NC}"
            echo -e "            ${DIM}login & refresh token, can run side by side${NC}"
            echo ""
            echo -e "  ${DIM}Change it: claude-switch mode <keychain|isolated>${NC}"
        else
            case "$NEW_MODE" in
                keychain|isolated)
                    set_config "mode" "$NEW_MODE"
                    echo -e "${GREEN}вњ“${NC} Mode set to ${BOLD}${NEW_MODE}${NC}"
                    if [ "$NEW_MODE" = "isolated" ]; then
                        echo -e "${DIM}Profiles from keychain mode aren't carried over вЂ” switch to a${NC}"
                        echo -e "${DIM}profile name and Claude will prompt you to log in for it.${NC}"
                    fi
                    echo -e "${DIM}Restart your shell or: source ~/.zshrc${NC}"
                    ;;
                *)
                    echo -e "${RED}вњ—${NC} Unknown mode '${NEW_MODE}'. Use ${BOLD}keychain${NC} or ${BOLD}isolated${NC}."
                    exit 1
                    ;;
            esac
        fi
        ;;

    _mode)
        # Internal: print the active storage mode for the shell wrapper.
        get_mode
        ;;

    _dirfor)
        # Internal: used by the shell wrapper in isolated mode. Ensure the
        # profile's config dir exists, record it active, and print its path so
        # the wrapper can export CLAUDE_CONFIG_DIR before launching claude.
        PROFILE="${2:-}"
        [ -z "$PROFILE" ] && exit 1
        DIR="$(profile_dir "$PROFILE")"
        mkdir -p "$DIR"
        set_active_profile "$PROFILE"
        echo "$DIR"
        ;;

    alias)
        NEW_ALIAS="${2:-}"
        if [ -z "$NEW_ALIAS" ]; then
            current=$(get_config "alias" "c")
            echo -e "Current shortcut: ${BOLD}${current}${NC}"
            echo -e "${DIM}Change it: claude-switch alias <name>${NC}"
        else
            set_config "alias" "$NEW_ALIAS"
            echo -e "${GREEN}вњ“${NC} Shortcut changed to ${BOLD}${NEW_ALIAS}${NC}"
            echo -e "${DIM}Restart your shell or: source ~/.zshrc${NC}"
        fi
        ;;

    -h|--help|help)
        usage
        ;;

    *)
        # Treat as profile name to switch to
        PROFILE="$CMD"

        if [ "$(get_mode)" = "isolated" ]; then
            # Switching == pointing CLAUDE_CONFIG_DIR at the profile's dir. The
            # shell wrapper does the export; when invoked directly we can only
            # record the choice and show the user the line to run.
            DIR="$(profile_dir "$PROFILE")"
            mkdir -p "$DIR"
            set_active_profile "$PROFILE"
            echo -e "${GREEN}в—Џ${NC} Active profile set to ${BOLD}${PROFILE}${NC} ${DIM}(isolated)${NC}"
            echo -e "  ${DIM}This shell still uses the old account. To switch here, run:${NC}"
            echo -e "  ${BOLD}export CLAUDE_CONFIG_DIR=$DIR${NC}"
            echo -e "  ${DIM}or use your shortcut (${BOLD}$(get_config alias c) ${PROFILE}${NC}${DIM}) which does this for you.${NC}"
            exit 0
        fi

        SOURCE="${PROFILE_PREFIX}${PROFILE}"

        if ! security find-generic-password -s "$SOURCE" -w >/dev/null 2>&1; then
            echo -e "${RED}вњ—${NC} No saved credentials for ${BOLD}${PROFILE}${NC}"
            echo ""
            local_profiles=$(list_profiles)
            if [ -n "$local_profiles" ]; then
                echo -e "  ${DIM}Available profiles:${NC}"
                while IFS= read -r p; do
                    [[ -z "$p" ]] && continue
                    echo -e "    ${BOLD}${p}${NC}"
                done <<< "$local_profiles"
            fi
            echo ""
            echo -e "  ${DIM}Save current: ${NC}${BOLD}claude-switch save ${PROFILE}${NC}"
            exit 1
        fi

        # Auto-save current (possibly refreshed) credentials before switching
        ACTIVE=$(get_active_profile)
        if [ -n "$ACTIVE" ] && [ "$ACTIVE" != "$PROFILE" ]; then
            CURRENT_CREDS=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -w 2>/dev/null) || true
            if [ -n "$CURRENT_CREDS" ]; then
                security add-generic-password -U -s "${PROFILE_PREFIX}${ACTIVE}" -a "$KEYCHAIN_ACCOUNT" -w "$CURRENT_CREDS" 2>/dev/null || true
            fi
        fi

        # Load target profile
        CREDS=$(security find-generic-password -s "$SOURCE" -w)
        security add-generic-password -U -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w "$CREDS" 2>/dev/null || \
        security add-generic-password    -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w "$CREDS"
        set_active_profile "$PROFILE"

        # Refresh if expired
        local_info=$(get_token_info "$KEYCHAIN_SERVICE" 2>/dev/null) || local_info=""
        local_status=$(echo "$local_info" | cut -d'|' -f1)
        if [ "$local_status" = "expired" ] || [ "$local_status" = "ready" ]; then
            echo -e "${DIM}  Token expired, refreshing...${NC}"
            do_refresh "$PROFILE"
        fi

        echo -e "${GREEN}в—Џ${NC} Switched to ${BOLD}${PROFILE}${NC}"
        ;;
esac
